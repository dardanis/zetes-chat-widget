APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://zetes-chat-widget.test:81
TELESCOPE_ALLOWED_EMAILS=dardan.ismajli@de.zetes.com,dardan@zetes.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_COOKIE=zetes_chat_widget_session
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=zetes-chat-widget.test
SANCTUM_STATEFUL_DOMAINS=zetes-chat-widget.test,zetes-chat-widget.test:81,localhost,localhost:4200,localhost:8000,127.0.0.1,127.0.0.1:8000,::1

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_GENERATION_MODEL=llama3
OLLAMA_TIMEOUT_SECONDS=120

REVERB_APP_ID=zetes-chat-widget
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_SERVER=reverb
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_SERVER_PATH=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

RAG_QUEUE=rag
RAG_CHUNK_TARGET_CHARS=1600
RAG_CHUNK_OVERLAP_CHARS=250
RAG_CHUNK_MIN_CHARS=300
RAG_RETRIEVAL_TOP_K=6
RAG_CRAWLER_MAX_PAGES=40
RAG_CRAWLER_REQUEST_TIMEOUT_SECONDS=10
RAG_CRAWLER_MAX_CONTENT_CHARS=120000
RAG_WIDGET_ALLOWED_ORIGINS=http://zetes-chat-widget.test:81,http://localhost,http://127.0.0.1
RAG_WIDGET_SESSION_TTL_SECONDS=86400
